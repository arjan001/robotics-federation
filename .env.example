# ============================================================
# Environment Variables for Inspire Robotics Challenge Platform
# ============================================================
# Copy this file to .env and fill in your values.
# Add these same variables to Netlify Dashboard > Site Settings > Environment Variables

# ============================================================
# SUPABASE
# ============================================================
# Your Supabase project URL (e.g. https://your-project.supabase.co)
SUPABASE_URL=

# Your Supabase anonymous/public key
SUPABASE_ANON_KEY=

# Your Supabase service role key (keep secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=
